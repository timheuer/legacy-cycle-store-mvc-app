@model AdventureWorks.Models.SiteLayoutModel
@{
    string categoryNameMenu, categoryNameList;
}
<div class="content">
    <div class="footerinner">
        <div id="PnlExpFooter">
            <div>
                @if (Model?.ProductCategories != null)
                {
                    @foreach (var category in Model.ProductCategories)
                    {
                        categoryNameMenu = category.Name + "Menu";
                        categoryNameList = category.Name + "List";
                        <div class="@categoryNameMenu">
                            <h1>
                                <b>@category.Name</b>
                            </h1>
                            <ul class="@categoryNameList">
                                @foreach (var subCategory in category.ProductSubcategories.ToList())
                                {
                                    <li>@subCategory.Name</li>
                                }
                            </ul>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>